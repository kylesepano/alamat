{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alamat://combat/affinity/affinity_chart.json",
  "title": "ALAMAT Combat Bible - affinity_chart",
  "description": "Type-effectiveness rows. Never duplicate affiliation definitions here; reference affiliation IDs.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "source": {
        "type": "string",
        "minLength": 1
      },
      "notes": {
        "type": "string"
      },
      "chart_id": {
        "type": "string",
        "pattern": "^AFC-?[A-Z0-9-]+$"
      },
      "attacker_affiliation_id": {
        "type": "string",
        "minLength": 1,
        "description": "Reference to affiliation_id; resolve through Combat Bible registry or Phase B library."
      },
      "defender_affiliation_id": {
        "type": "string",
        "minLength": 1,
        "description": "Reference to affiliation_id; resolve through Combat Bible registry or Phase B library."
      },
      "multiplier": {
        "type": "number",
        "minimum": 0
      },
      "rule": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "id",
      "uuid",
      "slug",
      "created_at",
      "updated_at",
      "version",
      "source",
      "notes",
      "chart_id",
      "chart_id",
      "attacker_affiliation_id",
      "defender_affiliation_id",
      "multiplier",
      "rule"
    ]
  },
  "examples": [
    [
      {
        "id": 11,
        "uuid": "00000000-0000-4000-8000-000000000011",
        "created_at": "2026-07-02T00:00:00+08:00",
        "updated_at": "2026-07-02T00:00:00+08:00",
        "version": "1.0.0",
        "source": "Phase D architecture example",
        "notes": "Example record for schema validation only; not production balance content.",
        "chart_id": "AFC-0001",
        "slug": "forest-vs-water",
        "attacker_affiliation_id": "AFF-CBT-FOREST",
        "defender_affiliation_id": "AFF-CBT-WATER",
        "multiplier": 1.15,
        "rule": "Roots and growth disrupt water-aligned recovery."
      }
    ]
  ]
}
