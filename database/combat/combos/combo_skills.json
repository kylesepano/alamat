{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alamat://combat/combos/combo_skills.json",
  "title": "ALAMAT Combat Bible - combo_skill",
  "description": "combo skill records for the Combat Bible.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "source": {
        "type": "string",
        "minLength": 1
      },
      "notes": {
        "type": "string"
      },
      "combo_id": {
        "type": "string",
        "pattern": "^CMB-?[A-Z0-9-]+$"
      },
      "required_monster_ids": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "required_skill_ids": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "result_skill_id": {
        "type": "string",
        "minLength": 1,
        "description": "Reference to skill_id; resolve through Combat Bible registry or Phase B library."
      },
      "conditions": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "cooldown": {
        "type": "integer",
        "minimum": 0
      },
      "description": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "id",
      "uuid",
      "slug",
      "created_at",
      "updated_at",
      "version",
      "source",
      "notes",
      "combo_id",
      "combo_id",
      "required_monster_ids",
      "required_skill_ids",
      "result_skill_id",
      "conditions",
      "cooldown",
      "description"
    ]
  },
  "examples": [
    [
      {
        "id": 23,
        "uuid": "00000000-0000-4000-8000-000000000023",
        "created_at": "2026-07-02T00:00:00+08:00",
        "updated_at": "2026-07-02T00:00:00+08:00",
        "version": "1.0.0",
        "source": "Phase D architecture example",
        "notes": "Example record for schema validation only; not production balance content.",
        "combo_id": "CMB-0001",
        "slug": "moon-eclipse-devour",
        "required_monster_ids": [
          "MON0015",
          "MON0020"
        ],
        "required_skill_ids": [],
        "result_skill_id": "SKL-CMB-0001",
        "conditions": [
          "weather:eclipse"
        ],
        "cooldown": 5,
        "description": "A future combo hook for Bakunawa and Minokawa during eclipse conditions."
      }
    ]
  ]
}
