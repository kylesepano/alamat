{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alamat://combat/formulas/healing_formulas.json",
  "title": "ALAMAT Combat Bible - healing_formula",
  "description": "healing formula records for the Combat Bible.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "source": {
        "type": "string",
        "minLength": 1
      },
      "notes": {
        "type": "string"
      },
      "formula_id": {
        "type": "string",
        "pattern": "^FRM-?[A-Z0-9-]+$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "kind": {
        "type": "string",
        "enum": [
          "physical",
          "magic",
          "healing",
          "critical",
          "status",
          "counter",
          "reflect",
          "capture",
          "escape",
          "summon",
          "dot",
          "hot"
        ]
      },
      "expression": {
        "type": "string",
        "minLength": 1
      },
      "variables": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "clamps": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "rounding": {
        "type": "string",
        "enum": [
          "none",
          "floor",
          "ceil",
          "round"
        ]
      },
      "documentation": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "id",
      "uuid",
      "slug",
      "created_at",
      "updated_at",
      "version",
      "source",
      "notes",
      "formula_id",
      "formula_id",
      "name",
      "kind",
      "expression",
      "variables",
      "clamps",
      "rounding",
      "documentation"
    ]
  },
  "examples": [
    [
      {
        "id": 13,
        "uuid": "00000000-0000-4000-8000-000000000013",
        "created_at": "2026-07-02T00:00:00+08:00",
        "updated_at": "2026-07-02T00:00:00+08:00",
        "version": "1.0.0",
        "source": "Phase D architecture example",
        "notes": "Example record for schema validation only; not production balance content.",
        "formula_id": "FRM-HEAL-0001",
        "slug": "standard-healing",
        "name": "standard healing",
        "kind": "healing",
        "expression": "(power + attack) * defense_modifier",
        "variables": [
          "power",
          "attack",
          "defense_modifier"
        ],
        "clamps": [
          {
            "min": 1
          }
        ],
        "rounding": "floor",
        "documentation": "Example formula record; production tuning belongs in balance passes."
      }
    ]
  ]
}
