{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alamat://combat/skills/common_skills.json",
  "title": "ALAMAT Combat Bible - common",
  "description": "Common skill definitions available through broad monster, NPC, item, or quest rules.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "source": {
        "type": "string",
        "minLength": 1
      },
      "notes": {
        "type": "string"
      },
      "skill_id": {
        "type": "string",
        "pattern": "^SKILL-?[A-Z0-9-]+$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "category": {
        "type": "string",
        "minLength": 1,
        "description": "Reference to library_skill_categories.code; resolve through Combat Bible registry or Phase B library."
      },
      "type": {
        "type": "string",
        "enum": [
          "physical",
          "magical",
          "spiritual",
          "support",
          "healing",
          "status",
          "summon",
          "field",
          "capture"
        ]
      },
      "affiliation": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to affiliation_id; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "element": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to damage_type_id; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "power": {
        "type": "integer",
        "minimum": 0
      },
      "accuracy": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      },
      "critical_rate": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      },
      "mana_cost": {
        "type": "integer",
        "minimum": 0
      },
      "stamina_cost": {
        "type": "integer",
        "minimum": 0
      },
      "faith_cost": {
        "type": "integer",
        "minimum": 0
      },
      "cooldown": {
        "type": "integer",
        "minimum": 0
      },
      "cast_time": {
        "type": "integer",
        "minimum": 0
      },
      "range": {
        "type": "string",
        "minLength": 1
      },
      "area_pattern": {
        "type": "string",
        "enum": [
          "single",
          "row",
          "column",
          "aoe",
          "cross",
          "cone",
          "chain",
          "random",
          "self",
          "ally",
          "party",
          "battlefield"
        ]
      },
      "target_type": {
        "type": "string",
        "minLength": 1,
        "description": "Reference to library_target_types.code; resolve through Combat Bible registry or Phase B library."
      },
      "priority": {
        "type": "integer",
        "minimum": -10,
        "maximum": 10
      },
      "animation_id": {
        "type": "string",
        "minLength": 1
      },
      "sound_id": {
        "type": "string",
        "minLength": 1
      },
      "icon": {
        "type": "string",
        "minLength": 1
      },
      "icon_filename": {
        "type": "string",
        "minLength": 1
      },
      "effect_animation_filename": {
        "type": "string",
        "minLength": 1
      },
      "cast_animation_filename": {
        "type": "string",
        "minLength": 1
      },
      "impact_animation_filename": {
        "type": "string",
        "minLength": 1
      },
      "icon_prompt": {
        "type": "string",
        "minLength": 1
      },
      "effect_prompt": {
        "type": "string",
        "minLength": 1
      },
      "animation_prompt": {
        "type": "string",
        "minLength": 1
      },
      "sound_effect_prompt": {
        "type": "string",
        "minLength": 1
      },
      "status_effect_id": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to status_effect_id; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "status_chance": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      },
      "can_crit": {
        "type": "boolean"
      },
      "can_miss": {
        "type": "boolean"
      },
      "required_weapon": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to equipment_categories.code; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "required_class": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to combat_classes.code; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "required_affiliation": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to affiliation_id; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "required_weather": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to weather_id; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "required_terrain": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to terrain_id; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "required_time": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Reference to active_times.code; resolve through Combat Bible registry or Phase B library."
          },
          {
            "type": "null"
          }
        ]
      },
      "ai_weight": {
        "type": "number",
        "minimum": 0
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "lore": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "id",
      "uuid",
      "slug",
      "created_at",
      "updated_at",
      "version",
      "source",
      "notes",
      "skill_id",
      "name",
      "category",
      "type",
      "affiliation",
      "element",
      "power",
      "accuracy",
      "critical_rate",
      "mana_cost",
      "stamina_cost",
      "faith_cost",
      "cooldown",
      "cast_time",
      "range",
      "area_pattern",
      "target_type",
      "priority",
      "animation_id",
      "sound_id",
      "icon",
      "icon_filename",
      "effect_animation_filename",
      "cast_animation_filename",
      "impact_animation_filename",
      "icon_prompt",
      "effect_prompt",
      "animation_prompt",
      "sound_effect_prompt",
      "status_effect_id",
      "status_chance",
      "can_crit",
      "can_miss",
      "required_weapon",
      "required_class",
      "required_affiliation",
      "required_weather",
      "required_terrain",
      "required_time",
      "ai_weight",
      "description",
      "lore"
    ]
  },
